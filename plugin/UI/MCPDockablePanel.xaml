<Page x:Class="revit_mcp_plugin.UI.MCPDockablePanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar - minimal like claude.ai -->
        <Border Grid.Row="0" Background="White" Padding="14,10" BorderBrush="#EDEBE8" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Claude for Revit" Foreground="#1A1A1A" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="  ⌄" Foreground="#999" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="7" Height="7" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StatusText" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#DDD" FontSize="11"/>
                    <TextBlock Text="Nuova chat" Foreground="#D97757" FontSize="11"
                               Cursor="Hand" MouseLeftButtonDown="ClearChat_Click"/>
                    <TextBlock Text="  |  " Foreground="#DDD" FontSize="11"/>
                    <TextBlock Text="Esporta" Foreground="#D97757" FontSize="11"
                               Cursor="Hand" MouseLeftButtonDown="ExportChat_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Background="White">
            <ItemsControl x:Name="ChatMessages">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding RowBackground}" Padding="20,16"
                                BorderBrush="#F0EEEB" BorderThickness="0,0,0,1">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                                        Background="{Binding AvatarBackground}" Margin="0,2,14,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Content -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding RoleLabel}" Foreground="{Binding RoleLabelColor}"
                                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Text, Mode=OneWay}"
                                             Foreground="{Binding TextColor, Mode=OneWay}"
                                             FontSize="14" TextWrapping="Wrap"
                                             FontFamily="{Binding FontFamily, Mode=OneWay}"
                                             IsReadOnly="True" AcceptsReturn="True"
                                             BorderThickness="0" Background="Transparent"
                                             VerticalScrollBarVisibility="Disabled"
                                             HorizontalScrollBarVisibility="Disabled"
                                             IsTabStop="False" Padding="0" Margin="0"
                                             SelectionBrush="#D97757"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Typing -->
        <Border Grid.Row="2" x:Name="TypingIndicator" Visibility="Collapsed"
                Background="#FAF9F7" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="6"
                        Background="#D97757" Margin="0,0,14,0">
                    <TextBlock Text="C" Foreground="White" FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" x:Name="TypingText" Text="Claude sta pensando..."
                           Foreground="#999" FontSize="14" FontStyle="Italic" VerticalAlignment="Center"/>
                <Border Grid.Column="2" CornerRadius="10" Padding="8,3" Margin="8,0,0,0"
                        Background="#F0EEEB" BorderBrush="#D4D1CC" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonDown="StopButton_Click">
                    <TextBlock Text="Stop" FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Input - claude.ai exact style -->
        <Border Grid.Row="3" Background="White" Padding="16,10,16,16">
            <Border Background="White" CornerRadius="22"
                    BorderBrush="#D4D1CC" BorderThickness="1"
                    Padding="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Text input -->
                    <Grid Grid.Row="0">
                        <TextBox x:Name="ChatInput"
                                 Background="Transparent" Foreground="#1A1A1A" CaretBrush="#1A1A1A"
                                 BorderThickness="0" Padding="16,14,50,14" FontSize="14"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MaxHeight="150" VerticalScrollBarVisibility="Auto"
                                 KeyDown="ChatInput_KeyDown"
                                 VerticalContentAlignment="Top"
                                 FontFamily="Segoe UI"/>
                        <!-- Placeholder -->
                        <TextBlock x:Name="Placeholder" Text="Rispondi... (Ctrl+Invio per inviare)" IsHitTestVisible="False"
                                   Foreground="#AAA" FontSize="14" Padding="18,14,0,0"
                                   FontFamily="Segoe UI"/>
                    </Grid>

                    <!-- Bottom bar with send button -->
                    <Grid Grid.Row="1" Margin="8,0,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Spacer (model and planning mode are managed automatically by Claude) -->
                        <Border Grid.Column="0" />

                        <!-- Send button -->
                        <Button x:Name="SendButton" Grid.Column="1" Click="Send_Click"
                                Background="Transparent" BorderThickness="0"
                                Padding="0" Cursor="Hand" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="14" Background="#D97757">
                                <Path Data="M5,3L19,12L5,21Z" Fill="White"
                                      Width="9" Height="11" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,0"/>
                            </Border>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
